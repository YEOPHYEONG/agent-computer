.DS_Store
node_modules/
dist/
.env
.env.*
*.log

# Keep real private workspace data out of public repos.
workspace/inbox/*
!workspace/inbox/README.md
workspace/projects/*
!workspace/projects/README.md
workspace/converted/*
!workspace/converted/README.md
workspace/reports/*
!workspace/reports/README.md
workspace/tasks/*
!workspace/tasks/README.md
workspace/archive/*
!workspace/archive/README.md
workspace/trash/*
!workspace/trash/README.md
workspace/outputs/*
!workspace/outputs/README.md
computer/memory/*
!computer/memory/README.md
!computer/memory/*.example.md
computer/memory/*.private.md
computer/memory/private/
workspace/reports/private/
workspace/tasks/private/
workspace/converted/private/
computer/system/last-dry-run.md
computer/system/file-move-log.md
computer/system/move-manifests/
computer/system/workspace-index.md
computer/system/workspace-map.md
computer/system/project-index.md
