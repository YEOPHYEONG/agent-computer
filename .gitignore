# Generated previews and temporary files.
*.tmp
*.bak
*.swp
~$*

# Optional large generated artifacts.
release-assets/
workspace/reports/**/*.png
workspace/converted/**/*.png
workspace/converted/**/*.jpg
workspace/converted/**/*.jpeg
